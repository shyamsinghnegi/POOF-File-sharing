# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Cloudflare R2 (file storage) — S3-compatible API
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Cloudflare D1 (metadata database) — accessed via REST API since we deploy on Vercel, not Cloudflare Workers
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=

# Upstash (rate limiting) — Redis over HTTP, fits serverless functions
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# VirusTotal (malware hash check on upload)
VIRUSTOTAL_API_KEY=

# Vercel Cron (authenticates scheduled cleanup requests to /api/cron/cleanup)
CRON_SECRET=
